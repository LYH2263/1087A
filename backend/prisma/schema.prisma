generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum BookStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  CANCELED
  REFUNDED
  RETURNING
  RETURNED
}

enum AfterSaleStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum AfterSaleType {
  RETURN
  EXCHANGE
}

enum AfterSaleReason {
  QUALITY_ISSUE
  WRONG_ITEM
  DAMAGED
  NOT_AS_DESCRIBED
  NO_LONGER_WANTED
  OTHER
}

enum PaymentMethod {
  WECHAT
  ALIPAY
  CARD
  COD
}

enum CouponType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum UserCouponStatus {
  AVAILABLE
  USED
  EXPIRED
}

enum NotificationType {
  ORDER_PAID
  ORDER_SHIPPED
  ORDER_COMPLETED
  ORDER_REFUNDED
}

enum MemberLevel {
  NORMAL
  SILVER
  GOLD
}

enum PointSource {
  ORDER_EARN
  ORDER_REFUND
  AFTER_SALE_REFUND
  ADMIN_ADJUST
}

model MemberProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  level           MemberLevel @default(NORMAL)
  totalPoints     Int         @default(0)
  availablePoints Int         @default(0)
  spentPoints     Int         @default(0)
  totalSpentCents Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  pointLogs       PointLog[]
}

model PointLog {
  id             String      @id @default(cuid())
  userId         String
  profileId      String
  source         PointSource
  points         Int
  balanceBefore  Int
  balanceAfter   Int
  orderId        String?
  afterSaleId    String?
  remark         String?
  createdAt      DateTime    @default(now())
  profile        MemberProfile @relation(fields: [profileId], references: [id])

  @@unique([orderId, source])
  @@unique([afterSaleId, source])
  @@index([userId, createdAt])
}

model User {
  id              String          @id @default(cuid())
  username        String          @unique
  email           String          @unique
  phone           String          @unique
  passwordHash    String
  role            Role            @default(USER)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  sessions        Session[]
  addresses       Address[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orders          Order[]
  passwordResets  PasswordReset[]
  userCoupons     UserCoupon[]
  afterSales      AfterSale[]
  notifications   Notification[]
  memberProfile   MemberProfile?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  books     Book[]
}

model Book {
  id              String             @id @default(cuid())
  title           String
  author          String
  isbn            String             @unique
  description     String
  priceCents      Int
  stock           Int
  coverUrl        String
  sales           Int                @default(0)
  status          BookStatus         @default(ACTIVE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  categoryId      String
  category        Category           @relation(fields: [categoryId], references: [id])
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]
  stockThreshold  StockThreshold?
  restockLogs     StockRestockLog[]
  afterSaleItems  AfterSaleItem[]
  specs           BookSpec[]
}

model BookSpec {
  id          String   @id @default(cuid())
  bookId      String
  name        String
  priceCents  Int
  stock       Int      @default(0)
  coverUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, name])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  specId    String   @default("")
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId, specId])
}

model WishlistItem {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  priceCents   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  book         Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  recipient    String
  phone        String
  line1        String
  city         String
  state        String
  postalCode   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Order {
  id                  String       @id @default(cuid())
  userId              String
  status              OrderStatus  @default(PENDING_PAYMENT)
  paymentMethod       PaymentMethod
  subtotalCents       Int
  discountCents       Int          @default(0)
  memberDiscountCents Int          @default(0)
  shippingFeeCents    Int          @default(0)
  totalCents          Int
  couponCode          String?
  userCouponId        String?
  recipient           String
  phone               String
  line1               String
  city                String
  state               String
  postalCode          String
  rating              Int?
  reviewText          String?
  reviewedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id])
  items               OrderItem[]
  userCoupon          UserCoupon?  @relation(fields: [userCouponId], references: [id])
  afterSales          AfterSale[]
  notifications       Notification[]
}

model OrderItem {
  id                String        @id @default(cuid())
  orderId           String
  bookId            String
  title             String
  author            String
  coverUrl          String
  priceCents        Int
  quantity          Int
  specName          String?
  specId            String?
  returnedQuantity  Int           @default(0)
  createdAt         DateTime      @default(now())
  order             Order         @relation(fields: [orderId], references: [id])
  book              Book          @relation(fields: [bookId], references: [id])
  afterSaleItems    AfterSaleItem[]
}

model AfterSale {
  id              String          @id @default(cuid())
  orderId         String
  userId          String
  type            AfterSaleType   @default(RETURN)
  status          AfterSaleStatus @default(PENDING)
  totalAmountCents Int            @default(0)
  reason          AfterSaleReason
  description     String?
  rejectReason    String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  order           Order           @relation(fields: [orderId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  items           AfterSaleItem[]
}

model AfterSaleItem {
  id            String    @id @default(cuid())
  afterSaleId   String
  orderItemId   String
  bookId        String
  title         String
  author        String
  coverUrl      String
  priceCents    Int
  quantity      Int
  specName      String?
  afterSale     AfterSale @relation(fields: [afterSaleId], references: [id])
  orderItem     OrderItem @relation(fields: [orderItemId], references: [id])
  book          Book      @relation(fields: [bookId], references: [id])
}

model Coupon {
  id                String        @id @default(cuid())
  name              String
  code              String        @unique
  type              CouponType
  discountAmountCents Int?
  discountPercentage Float?
  maxDiscountCents  Int?
  minAmountCents    Int           @default(0)
  totalQuantity     Int
  claimedQuantity   Int           @default(0)
  limitPerUser      Int           @default(1)
  validFrom         DateTime
  validUntil        DateTime
  status            CouponStatus  @default(ACTIVE)
  description       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  userCoupons       UserCoupon[]
}

model UserCoupon {
  id         String           @id @default(cuid())
  userId     String
  couponId   String
  status     UserCouponStatus @default(AVAILABLE)
  usedAt     DateTime?
  orderId    String?
  claimedAt  DateTime         @default(now())
  expiredAt  DateTime?
  user       User             @relation(fields: [userId], references: [id])
  coupon     Coupon           @relation(fields: [couponId], references: [id])
  usedOrders Order[]

  @@unique([userId, couponId])
}

model StockThreshold {
  id        String   @id @default(cuid())
  bookId    String?  @unique
  threshold Int
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book?    @relation(fields: [bookId], references: [id])
}

model StockRestockLog {
  id        String   @id @default(cuid())
  bookId    String
  quantity  Int
  oldStock  Int
  newStock  Int
  operator  String
  createdAt DateTime @default(now())
  book      Book     @relation(fields: [bookId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  orderId   String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id])
  order     Order?           @relation(fields: [orderId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, isRead])
}
