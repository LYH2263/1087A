generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum BookStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  CANCELED
  REFUNDED
}

enum PaymentMethod {
  WECHAT
  ALIPAY
  CARD
  COD
}

enum CouponType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum UserCouponStatus {
  AVAILABLE
  USED
  EXPIRED
}

model User {
  id           String          @id @default(cuid())
  username     String          @unique
  email        String          @unique
  phone        String          @unique
  passwordHash String
  role         Role            @default(USER)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sessions     Session[]
  addresses    Address[]
  cartItems    CartItem[]
  wishlistItems WishlistItem[]
  orders       Order[]
  passwordResets PasswordReset[]
  userCoupons  UserCoupon[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  books     Book[]
}

model Book {
  id          String     @id @default(cuid())
  title       String
  author      String
  isbn        String     @unique
  description String
  priceCents  Int
  stock       Int
  coverUrl    String
  sales       Int        @default(0)
  status      BookStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  cartItems   CartItem[]
  wishlistItems WishlistItem[]
  orderItems  OrderItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model WishlistItem {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  priceCents   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  book         Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  recipient    String
  phone        String
  line1        String
  city         String
  state        String
  postalCode   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Order {
  id            String       @id @default(cuid())
  userId        String
  status        OrderStatus  @default(PENDING_PAYMENT)
  paymentMethod PaymentMethod
  subtotalCents Int
  discountCents Int          @default(0)
  totalCents    Int
  couponCode    String?
  userCouponId  String?
  recipient     String
  phone         String
  line1         String
  city          String
  state         String
  postalCode    String
  rating        Int?
  reviewText    String?
  reviewedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id])
  items         OrderItem[]
  userCoupon    UserCoupon?  @relation(fields: [userCouponId], references: [id])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  bookId    String
  title     String
  author    String
  coverUrl  String
  priceCents Int
  quantity  Int
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])
}

model Coupon {
  id                String        @id @default(cuid())
  name              String
  code              String        @unique
  type              CouponType
  discountAmountCents Int?
  discountPercentage Float?
  maxDiscountCents  Int?
  minAmountCents    Int           @default(0)
  totalQuantity     Int
  claimedQuantity   Int           @default(0)
  limitPerUser      Int           @default(1)
  validFrom         DateTime
  validUntil        DateTime
  status            CouponStatus  @default(ACTIVE)
  description       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  userCoupons       UserCoupon[]
}

model UserCoupon {
  id         String           @id @default(cuid())
  userId     String
  couponId   String
  status     UserCouponStatus @default(AVAILABLE)
  usedAt     DateTime?
  orderId    String?
  claimedAt  DateTime         @default(now())
  expiredAt  DateTime?
  user       User             @relation(fields: [userId], references: [id])
  coupon     Coupon           @relation(fields: [couponId], references: [id])
  usedOrders Order[]

  @@unique([userId, couponId])
}
